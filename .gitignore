# Built application files
*.apk
*.aar
*.ap_
*.aab

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/
release/

# Gradle files
.gradle/
build/

# Local configuration file (sdk path, etc)
local.properties

# Proguard folder generated by Eclipse
proguard/

# Log Files
*.log

# Heap dumps
*.hprof

# Android Studio Navigation editor temp files
.navigation/

# Android Studio captures folder
captures/

# IntelliJ
*.iml
.idea/

# External native build folder generated in Android Studio 2.2 and later
.externalNativeBuild
.cxx/

# Keystore files
*.jks
*.keystore

# OS files
.DS_Store
Thumbs.db

# Signing config
signing.properties

# Temp/debug files from Claude sessions
*.txt
fix_*.php
web_auth_original.php
..tmp_*
