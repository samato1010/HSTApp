<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/formContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Estado de Carga -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Estado de carga *"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"
            android:layout_marginTop="8dp" />

        <Spinner
            android:id="@+id/spEstadoCarga"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/input_bg"
            android:padding="8dp" />

        <!-- Chapa/Baliza -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chapa / Baliza *"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/spChapaBaliza"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="4dp"
            android:background="@drawable/input_bg"
            android:padding="8dp" />

        <EditText
            android:id="@+id/etOtraChapa"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Especificar chapa..."
            android:inputType="text"
            android:background="@drawable/input_bg"
            android:padding="12dp"
            android:textSize="14sp"
            android:visibility="gone"
            android:layout_marginBottom="12dp" />

        <!-- Comentario -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Comentario (opcional)"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/etComentario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Observaciones del extintor..."
            android:inputType="textMultiLine"
            android:minLines="2"
            android:maxLines="4"
            android:background="@drawable/input_bg"
            android:padding="12dp"
            android:textSize="14sp"
            android:gravity="top" />

    </LinearLayout>
</ScrollView>
